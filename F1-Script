local function formatQualyTime(seconds)
    local mins=math.floor(seconds/60)
    local secs=math.floor(seconds%60)
    local millis=math.floor((seconds%1)*1000)
    return string.format("%02d:%02d.%03d",mins,secs,millis)
end

local function createStartLine(position,lookVector)
    if lineFolder then lineFolder:Destroy()end
    
    lineFolder=Instance.new("Folder")
    lineFolder.Name="QualyStartLine"
    lineFolder.Parent=workspace
    
    local rayOrigin=position
    local rayDirection=Vector3.new(0,-50,0)
    local raycastParams=RaycastParams.new()
    raycastParams.FilterType=Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances={L.Character,lineFolder}
    
    local rayResult=workspace:Raycast(rayOrigin,rayDirection,raycastParams)
    local groundY=rayResult and rayResult.Position.Y or position.Y-3
    
    local rightVector=Vector3.new(-lookVector.Z,0,lookVector.X).Unit
    local lineCenter=Vector3.new(position.X,groundY+LINE_HEIGHT/2,position.Z)
    
    linePosition=lineCenter
    lineNormal=lookVector
    lineRightVector=rightVector
    
    local line=Instance.new("Part")
    line.Name="StartLine"
    line.Size=Vector3.new(LINE_LENGTH,LINE_HEIGHT,LINE_WIDTH)
    line.Position=lineCenter
    line.CFrame=CFrame.new(lineCenter,lineCenter+rightVector)*CFrame.Angles(0,math.rad(90),0)
    line.Anchored=true
    line.CanCollide=false
    line.Material=Enum.Material.Neon
    line.BrickColor=BrickColor.new("Lime green")
    line.Transparency=0.2
    line.Parent=lineFolder
    
    local light=Instance.new("PointLight",line)
    light.Color=Color3.fromRGB(0,255,0)
    light.Brightness=3
    light.Range=30
    
    for i=-1,1,2 do
        local marker=Instance.new("Part")
        marker.Size=Vector3.new(2,4,2)
        marker.Position=lineCenter+(rightVector*(LINE_LENGTH/2)*i)
        marker.Anchored=true
        marker.CanCollide=false
        marker.Material=Enum.Material.Neon
        marker.BrickColor=BrickColor.new("Really red")
        marker.Transparency=0.3
        marker.Parent=lineFolder
        
        local markerLight=Instance.new("PointLight",marker)
        markerLight.Color=Color3.fromRGB(255,0,0)
        markerLight.Brightness=2
        markerLight.Range=15
    end
    
    for i=0,LINE_LENGTH,5 do
        local gridLine=Instance.new("Part")
        gridLine.Size=Vector3.new(0.2,LINE_HEIGHT+0.3,LINE_WIDTH+0.3)
        gridLine.Position=lineCenter-(rightVector*LINE_LENGTH/2)+(rightVector*i)
        gridLine.CFrame=CFrame.new(gridLine.Position,gridLine.Position+rightVector)
        gridLine.Anchored=true
        gridLine.CanCollide=false
        gridLine.Material=Enum.Material.Neon
        gridLine.BrickColor=BrickColor.new("White")
        gridLine.Transparency=0.4
        gridLine.Parent=lineFolder
    end
    
    return line
end

local function isPlayerInVehicle(targetPlayer)
    if not targetPlayer.Character then return false end
    local humanoid=targetPlayer.Character:FindFirstChild("Humanoid")
    if not humanoid then return false end
    if humanoid.SeatPart and humanoid.SeatPart:IsA("VehicleSeat")then return true end
    return false
end

local function getVehiclePosition(targetPlayer)
    if not targetPlayer.Character then return nil end
    if not isPlayerInVehicle(targetPlayer)then return nil end
    local humanoid=targetPlayer.Character:FindFirstChild("Humanoid")
    if humanoid and humanoid.SeatPart then
        local vehicle=humanoid.SeatPart.Parent
        if vehicle then
            if vehicle.PrimaryPart then return vehicle.PrimaryPart.Position end
            return humanoid.SeatPart.Position
        end
    end
    return nil
end

local function isWithinLineBounds(vehiclePos)
    if not linePosition or not lineRightVector or not lineNormal then return false end
    local toVehicle=vehiclePos-linePosition
    local lateralDistance=math.abs(toVehicle:Dot(lineRightVector))
    local frontalDistance=math.abs(toVehicle:Dot(lineNormal))
    local isWithinWidth=lateralDistance<=(LINE_LENGTH/2)+2
    local isNearLine=frontalDistance<=3
    return isWithinWidth and isNearLine
end

local function isInFrontOfLine(vehiclePos)
    if not linePosition or not lineNormal then return nil end
    local toVehicle=vehiclePos-linePosition
    local dotProduct=toVehicle:Dot(lineNormal)
    return dotProduct>0
end

