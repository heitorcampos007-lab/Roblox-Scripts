local timerRunning=false
local timerPaused=false
local startTime=0
local pausedTime=0

local function formatTime(t)
    local min=math.floor(t/60)
    local sec=math.floor(t%60)
    local ms=math.floor((t%1)*100)
    return string.format("%02d : %02d , %02d",min,sec,ms)
end

R.RenderStepped:Connect(function()
    if timerRunning and not timerPaused then
        local elapsed=tick()-startTime
        TimeDisplay.Text=formatTime(elapsed)
    end
end)

BtnIniciar.MouseButton1Click:Connect(function()
    if not timerRunning then
        timerRunning=true
        timerPaused=false
        startTime=tick()-pausedTime
        BtnIniciar.Text="Parar"
        BtnIniciar.BackgroundColor3=Color3.fromRGB(255,50,50)
    elseif not timerPaused then
        timerPaused=true
        pausedTime=tick()-startTime
        BtnIniciar.Text="Retomar"
        BtnIniciar.BackgroundColor3=Color3.fromRGB(100,100,255)
    else
        timerPaused=false
        startTime=tick()-pausedTime
        BtnIniciar.Text="Parar"
        BtnIniciar.BackgroundColor3=Color3.fromRGB(255,50,50)
    end
end)

