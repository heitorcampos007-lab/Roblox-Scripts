local function checkLineCrossing()
    if not linePosition or not lineNormal or not lineRightVector then return end
    local currentTime=tick()
    
    for _,targetPlayer in pairs(P:GetPlayers())do
        if not isPlayerInVehicle(targetPlayer)then continue end
        local vehiclePos=getVehiclePosition(targetPlayer)
        if not vehiclePos then continue end
        if not isWithinLineBounds(vehiclePos)then continue end
        
        initPlayerData(targetPlayer)
        local data=playersData[targetPlayer.UserId]
        local currentlyInFront=isInFrontOfLine(vehiclePos)
        
        if currentTime-data.lastDetectionTime<DEBOUNCE_TIME then
            data.wasInFront=currentlyInFront
            continue
        end
        
        if data.wasInFront~=nil and data.wasInFront~=currentlyInFront then
            data.lastDetectionTime=currentTime
            
            if not data.isQualifying then
                data.isQualifying=true
                data.lapCount=0
                qTimer.Text="🏁 "..targetPlayer.Name.." - Aquecimento"
                qTimer.TextColor3=Color3.fromRGB(255,200,100)
                globalTimerRunning=false
                currentTrackedPlayer=targetPlayer
            elseif data.lapCount==0 then
                data.lapCount=1
                data.startTime=tick()
                globalTimerRunning=true
                globalStartTime=tick()
                globalTimerPaused=false
                currentTrackedPlayer=targetPlayer
                qTimer.Text="⏱️ "..targetPlayer.Name.." - 00:00.000"
                qTimer.TextColor3=Color3.fromRGB(100,255,100)
                qResetBtn.Visible=false
                qStopBtn.Visible=true
                qResetPausedBtn.Visible=false
                qContinueBtn.Visible=false
                qMarkBtn.Position=UDim2.new(0,10,0,165)
                qRemoveBtn.Position=UDim2.new(0,10,0,220)
                qScroll.Position=UDim2.new(0,10,0,270)
            elseif data.lapCount==1 then
                local finalTime=tick()-data.startTime
                globalTimerRunning=false
                qTimer.Text="🏁 "..targetPlayer.Name.." - "..formatQualyTime(finalTime)
                qTimer.TextColor3=Color3.fromRGB(100,200,255)
                qStopBtn.Visible=false
                addTimeToList(targetPlayer.Name,finalTime)
                task.wait(2)
                data.isQualifying=false
                data.lapCount=0
                data.startTime=0
                data.wasInFront=nil
                data.lastDetectionTime=0
            end
        end
        data.wasInFront=currentlyInFront
    end
end

local function updateQualyTimer()
    if globalTimerRunning and globalStartTime>0 and not globalTimerPaused then
        local currentTime=tick()-globalStartTime
        qTimer.Text=formatQualyTime(currentTime)
    end
    if currentTrackedPlayer and playersData[currentTrackedPlayer.UserId]then
        local data=playersData[currentTrackedPlayer.UserId]
        if data.isQualifying and data.lapCount>=1 and data.startTime>0 and not globalTimerPaused then
            local currentTime=tick()-data.startTime
            qTimer.Text=formatQualyTime(currentTime)
        end
    end
end

