--========================================================--
local function createStartLine(position, lookVector)
	if startLineFolder then startLineFolder:Destroy() end
	startLineFolder = Instance.new("Folder")
	startLineFolder.Name = "F1StartLine"
	startLineFolder.Parent = workspace

	local rp = RaycastParams.new()
	rp.FilterType = Enum.RaycastFilterType.Exclude
	rp.FilterDescendantsInstances = {player.Character, startLineFolder}
	local hit = workspace:Raycast(position, Vector3.new(0, -50, 0), rp)
	local groundY = hit and hit.Position.Y or (position.Y - 3)

	local rightVec = Vector3.new(-lookVector.Z, 0, lookVector.X).Unit
	local center = Vector3.new(position.X, groundY + LINE_HEIGHT / 2, position.Z)

	startLinePosition = center
	startLineNormal   = lookVector
	startLineRight    = rightVec

	local TILE_SIZE = 4
	local TILE_DEPTH = LINE_WIDTH_3D + 0.1
	local TILE_HEIGHT = LINE_HEIGHT
	local numTiles = math.floor(LINE_LENGTH / TILE_SIZE)
	local startOffset = -(numTiles * TILE_SIZE) / 2 + TILE_SIZE / 2

	for i = 0, numTiles - 1 do
		local tile = Instance.new("Part")
		tile.Size = Vector3.new(TILE_SIZE, TILE_HEIGHT, TILE_DEPTH)
		local tilePos = center + rightVec * (startOffset + i * TILE_SIZE)
		tile.CFrame = CFrame.new(tilePos, tilePos + rightVec)
		tile.Anchored = true
		tile.CanCollide = false
		tile.Material = Enum.Material.SmoothPlastic
		tile.Transparency = 0
		tile.BrickColor = (i % 2 == 0) and BrickColor.new("Black") or BrickColor.new("White")
		tile.Parent = startLineFolder
	end
end

local function isWithinStartLine(pos)
	if not startLinePosition or not startLineRight or not startLineNormal then return false end
	local toPos = pos - startLinePosition
	return math.abs(toPos:Dot(startLineRight)) <= (LINE_LENGTH / 2) + 2
		and math.abs(toPos:Dot(startLineNormal)) <= 3
end

local function isInFrontOfStartLine(pos)
	if not startLinePosition or not startLineNormal then return nil end
	return (pos - startLinePosition):Dot(startLineNormal) > 0
end

local startLineData = {}
local startLineConn = nil

local function getCharPos(plr)
	local char = plr.Character
	if not char then return nil end
	local hum = char:FindFirstChild("Humanoid")
	if hum and hum.SeatPart and hum.SeatPart:IsA("VehicleSeat") then
		local vehicle = hum.SeatPart.Parent
		if vehicle then
			if vehicle.PrimaryPart then return vehicle.PrimaryPart.Position end
			return hum.SeatPart.Position
		end
	end
	return nil
end

local function checkStartLineCrossing()
	if not startLinePosition then return end
	local now = tick()
	for _, plr in pairs(Players:GetPlayers()) do
		local pos = getCharPos(plr)
		if not pos then continue end
		if not isWithinStartLine(pos) then continue end
		if not startLineData[plr.UserId] then
			startLineData[plr.UserId] = {wasInFront = nil, lastTime = 0}
		end
		local d = startLineData[plr.UserId]
		if now - d.lastTime < DEBOUNCE_TIME then
			d.wasInFront = isInFrontOfStartLine(pos)
			continue
		end
		local inFront = isInFrontOfStartLine(pos)
		if d.wasInFront ~= nil and d.wasInFront ~= inFront then
			d.lastTime = now
			local dpEntry = dataP[plr]
			if dpEntry then
				if not dpEntry.active and not dpEntry.cool then
					task.delay(DELAY, function()
						if dpEntry and not dpEntry.cool then
							dpEntry.active = true
							dpEntry.start = tick()
						end
					end)
				elseif dpEntry.active then
					local lap = tick() - dpEntry.start
					if not bestLap[plr.Name] or lap < bestLap[plr.Name] then
						bestLap[plr.Name] = lap
						playerNames[plr.Name] = getPlayerTag(plr)
						if lap < record then
							record = lap
							showFastLap(getPlayerTag(plr), lap)
						end
						updateBoard()
					end
					dpEntry.cool = true
					dpEntry.active = false
					task.delay(DELAY, function()
						if dpEntry then
							dpEntry.cool = false
							dpEntry.active = true
							dpEntry.start = tick()
						end
					end)
				end
			end
		end
		d.wasInFront = inFront
	end
end

