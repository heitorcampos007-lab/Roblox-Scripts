local velActive = false
local velLimit = 0
local velData = {}

local function getVehicleSpeed(char)
	local hum = char:FindFirstChildWhichIsA("Humanoid")
	if not hum then return nil, 0 end
	local seat = hum.SeatPart
	if not seat or not seat:IsA("VehicleSeat") then return nil, 0 end
	local vehicle = seat:FindFirstAncestorWhichIsA("Model")
	if not vehicle then return nil, 0 end
	for _, obj in ipairs(vehicle:GetDescendants()) do
		if obj:IsA("NumberValue") and obj.Name:lower():find("speed") then
			return obj, obj.Value
		end
	end
	return nil, 0
end

local alertFolder = Instance.new("Folder", gui)

local function showSpeedAlert(name, vel)
	local t = Instance.new("TextLabel", alertFolder)
	t.Size = UDim2.new(0.35, 0, 0, 25)
	local count = #alertFolder:GetChildren()
	t.Position = UDim2.new(0.325, 0, 0.05 + (count - 1) * 0.035, 0)
