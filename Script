--========================================================--
-- LINHA DE CHEGADA (FIXA)
--========================================================--
local P1 = Vector3.new(312.2, 3, -32.5)
local P2 = Vector3.new(312.2, 3, -94.1)
local CENTER = (P1 + P2) / 2
local LENGTH = (P1 - P2).Magnitude
local WIDTH = 6

local function inside(root)
	local pos = root.Position
	local AP = pos - P1
	local AB = (P2 - P1)
	local len = AB.Magnitude
	local ABn = AB.Unit
	local proj = AP:Dot(ABn)
	if proj < 0 or proj > len then return false end
	local closest = P1 + ABn * proj
	return (pos - closest).Magnitude < WIDTH
end

local function isInVehicle(plr)
	local char = plr.Character
	if not char then return false end
	local hum = char:FindFirstChildWhichIsA("Humanoid")
	if not hum then return false end
	return hum.SeatPart ~= nil and hum.SeatPart:IsA("VehicleSeat")
end

--========================================================--
-- FORMATOS DE TEMPO
--========================================================--
local function fmtDynamic(t)
	if not t then return "--.---" end
	local mins = math.floor(t / 60)
	local secs = math.floor(t % 60)
	local ms = math.floor((t % 1) * 1000)
	if mins > 0 then
		return string.format("%02d:%02d.%03d", mins, secs, ms)
	else
		return string.format("%.3f", t)
	end
end

local function fmtDiff(diff)
	if not diff or math.abs(diff) > 10000 then return "+--.---" end
	if math.abs(diff) < 0.001 then return "0.000" end
	local absDiff = math.abs(diff)
	local formattedTime = string.format("%.3f", absDiff)
	if diff > 0 then return "+" .. formattedTime
	elseif diff < 0 then return formattedTime
	else return "0.000" end
end

