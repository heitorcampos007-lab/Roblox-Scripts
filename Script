-- LOGICA PRINCIPAL DE VOLTAS
--========================================================--
local DELAY = 2

local function getPlayerTag(playerObject)
	local nameToUse = playerObject.DisplayName or playerObject.Name
	return string.upper(string.sub(nameToUse, 1, 3))
end

updateBoard = function()
	local arr = {}

	local onlinePlayers = {}
	for _, plr in ipairs(Players:GetPlayers()) do
		onlinePlayers[plr.Name] = plr
	end

	local seenNames = {}
	for name, bestTime in pairs(bestLap) do
		if not seenNames[name] then
			seenNames[name] = true
			table.insert(arr, {
				playerName = name,
				displayTag = playerNames[name] or string.upper(string.sub(name, 1, 3)),
				t = bestTime,
				sortTime = bestTime
			})
		end
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		if not bestLap[plr.Name] then
			table.insert(arr, {
				playerName = plr.Name,
				displayTag = getPlayerTag(plr),
				t = nil,
				sortTime = math.huge
			})
		end
	end

	table.sort(arr, function(a, b) return a.sortTime < b.sortTime end)
	record = arr[1] and arr[1].t or math.huge

	for i = 1, 20 do
		if arr[i] then
			local entry = arr[i]
			rowPlayerRef[i] = entry.playerName
			rows[i].name.Text = entry.displayTag
			rows[i].soft.Text = "S"
			if entry.t then
				local diff = entry.t - record
				if math.abs(diff) < 0.001 then
					rows[i].time.Text = fmtDynamic(entry.t)
					rows[i].time.TextColor3 = Color3.fromRGB(128, 0, 128)
				else
					rows[i].time.Text = fmtDiff(diff)
					rows[i].time.TextColor3 = Color3.fromRGB(255, 255, 255)
				end
				rows[i].xBtn.Visible = true
			else
				rows[i].time.Text = "NO TIME"
				rows[i].time.TextColor3 = Color3.fromRGB(255, 255, 255)
				rows[i].xBtn.Visible = false
			end
		else
			rowPlayerRef[i] = nil
			rows[i].name.Text = ""
			rows[i].soft.Text = ""
			rows[i].time.Text = ""
			rows[i].xBtn.Visible = false
		end
	end
end

Run.Heartbeat:Connect(function()
	for _, plr in ipairs(Players:GetPlayers()) do
		dataP[plr] = dataP[plr] or {active=false, start=0, cool=false}
		playerNames[plr.Name] = getPlayerTag(plr)
	end
	updateBoard()
end)

Players.PlayerAdded:Connect(updateBoard)

Players.PlayerRemoving:Connect(function(plr)
