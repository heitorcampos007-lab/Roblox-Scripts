--========================================================--
-- VISIBILIDADE DA CÂMERA NO MUNDO
--========================================================--
local function setCameraPartVisible(cd, visible)
    if not cd then return end
    local transparency = visible and 0 or 1
    if cd.camPart then
        cd.camPart.Transparency = transparency
    end
    if cd.led then
        cd.led.Transparency = visible and 0.2 or 1
    end
end

local function showAllCameraParts()
    for _, cd in ipairs(cameras) do
        setCameraPartVisible(cd, true)
    end
end

local function hideCurrentCameraPart()
    if currentCamIndex and cameras[currentCamIndex] then
        setCameraPartVisible(cameras[currentCamIndex], false)
    end
end

--========================================================--
-- FUNÇÕES
--========================================================--
local function updateCamCount()
    camCountLabel.Text = "Câmeras: " .. #cameras .. " / " .. CONFIG.maxCameras
end

local function setCharParts(transparency)
    local character = player.Character
    if not character then return end
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("Decal") then
            part.LocalTransparencyModifier = transparency
        end
    end
end

local function restoreCamera()
    if currentCamIndex and cameras[currentCamIndex] then
        setCameraPartVisible(cameras[currentCamIndex], true)
    end

    workspaceCam.CameraType = Enum.CameraType.Custom
    setCharParts(0)
    recLabel.Visible = false
    coordsLabel.Visible = false
    wasdHint.Visible = false
    camNameLabel.Text = ""
    camInstructLabel.Visible = true
    statusText.Text = "[ F ] FECHAR   |   [ W A S D ] MOVER CÂMERA   |   Câmera desativada"
end

local function switchToCamera(index)
    if switchCooldown then return end
    local cd = cameras[index]
    if not cd or not cd.camPart then return end

    switchCooldown = true
    staticOverlay.Visible = true
    task.wait(0.18)
    staticOverlay.Visible = false
    switchCooldown = false

    if currentCamIndex and cameras[currentCamIndex] then
        setCameraPartVisible(cameras[currentCamIndex], true)
    end

    currentCamIndex = index

    setCameraPartVisible(cd, false)

    setCharParts(1)

    workspaceCam.CameraType = Enum.CameraType.Scriptable
    workspaceCam.FieldOfView = CONFIG.cameraFOV
    workspaceCam.CFrame = cd.camPart.CFrame

    coordsLabel.Visible = true
    wasdHint.Visible = true

    camNameLabel.Text = "● CAM " .. string.format("%02d", index) .. "   " .. os.date("%H:%M:%S")
    recLabel.Visible = true
    camInstructLabel.Visible = false
    statusText.Text = "[ F ] FECHAR   |   [ W A S D ] MOVER CÂMERA   |   Visualizando CAM " .. string.format("%02d", index)
end

