        onDelete(i)
    end)
end

function updateCameraListBoth()
    for _, child in ipairs(camListScrollLeft:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, child in ipairs(camListScrollRight:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    local function doDelete(idx)
        local cd = cameras[idx]
        if cd then
            setCameraPartVisible(cd, true)
            if cd.camPart then cd.camPart:Destroy() end
            if cd.lens then cd.lens:Destroy() end
            if cd.led then cd.led:Destroy() end
            table.remove(cameras, idx)
            if currentCamIndex == idx then
                currentCamIndex = nil
                restoreCamera()
            elseif currentCamIndex and currentCamIndex > idx then
                currentCamIndex = currentCamIndex - 1
            end
            updateCamCount()
            updateCameraListBoth()
        end
    end

    for i = 1, #cameras do
        buildCamButton(camListScrollLeft, i, doDelete)
        buildCamButton(camListScrollRight, i, doDelete)
    end

    local h = #cameras * 50
    camListScrollLeft.CanvasSize = UDim2.new(0, 0, 0, h)
    camListScrollRight.CanvasSize = UDim2.new(0, 0, 0, h)
end

local function addCamera()
    if #cameras >= CONFIG.maxCameras then
        addCamBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
        task.wait(0.5)
        addCamBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        return
    end
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local camPart = Instance.new("Part")
    camPart.Name = "SecurityCamera_" .. (#cameras + 1)
    camPart.Size = CONFIG.cameraPartSize
    camPart.Anchored = true
    camPart.CanCollide = false
    camPart.CastShadow = false
    camPart.Transparency = 0
    camPart.Color = Color3.fromRGB(50, 50, 50)
    camPart.Material = Enum.Material.SmoothPlastic
    camPart.CFrame = hrp.CFrame * CFrame.new(0, 2, -3) * CFrame.Angles(math.rad(-10), 0, 0)
    camPart.Parent = workspace

    local ledPart = Instance.new("Part")
    ledPart.Size = Vector3.new(0.12, 0.12, 0.12)
    ledPart.Anchored = true
    ledPart.CanCollide = false
    ledPart.Material = Enum.Material.Neon
    ledPart.Color = Color3.fromRGB(0, 255, 80)
    ledPart.Transparency = 0.2
    ledPart.CFrame = camPart.CFrame * CFrame.new(0.18, 0.15, -0.4)
    ledPart.Parent = workspace

    table.insert(cameras, { camPart = camPart, led = ledPart })

    if currentCamIndex == nil and tabletOpen then
        switchToCamera(#cameras)
    end

    addCamBtn.Text = "✔  Adicionada!"
    addCamBtn.TextColor3 = Color3.fromRGB(120, 255, 160)
    task.wait(1.2)
    addCamBtn.Text = "📷  Adicionar Câmera"
    addCamBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

    updateCamCount()
    updateCameraListBoth()
end

local function setTabletVisible(visible)
    tabletOpen = visible
    if visible then
        tabletFrame.Visible = true
        updateCameraListBoth()
        if currentCamIndex and cameras[currentCamIndex] then
            task.wait(0.05)
            switchToCamera(currentCamIndex)
        end
    else
        restoreCamera()
        showAllCameraParts()
        currentCamIndex = nil
        tabletFrame.Visible = false
        setCharParts(0)
        workspaceCam.CameraType = Enum.CameraType.Custom
    end
end

--========================================================--
-- HEARTBEAT - câmera + WASD (SEM mover personagem)
--========================================================--
RunService.Heartbeat:Connect(function()
    if not (tabletOpen and currentCamIndex and cameras[currentCamIndex]) then return end
    local cd = cameras[currentCamIndex]
    if not (cd.camPart and cd.camPart.Parent) then return end

    local rotX, rotY = 0, 0
    local speed = CONFIG.rotSpeed

    if UserInputService:IsKeyDown(Enum.KeyCode.W) then rotX = speed end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then rotX = -speed end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then rotY = speed end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then rotY = -speed end

    if rotX ~= 0 or rotY ~= 0 then
        cd.camPart.CFrame = cd.camPart.CFrame
            * CFrame.Angles(math.rad(rotX), math.rad(rotY), 0)
    end

    workspaceCam.CameraType = Enum.CameraType.Scriptable
    workspaceCam.CFrame = cd.camPart.CFrame

    local pos = cd.camPart.CFrame.Position
    coordsLabel.Text = string.format(
        "X %.0f  Y %.0f  Z %.0f",
        pos.X, pos.Y, pos.Z
    )
end)

