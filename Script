	t.Font = Enum.Font.GothamBold
	t.ZIndex = 5
	Instance.new("UICorner", t).CornerRadius = UDim.new(0, 6)
	task.delay(2, function()
		for i = 1, 20 do
			task.wait(0.025)
			t.BackgroundTransparency = i / 20
			t.TextTransparency = i / 20
		end
		t:Destroy()
	end)
end

local function stopVelTracking(plr)
	if velData[plr] then
		if velData[plr].conn then velData[plr].conn:Disconnect() end
		if velData[plr].bill and velData[plr].bill.Parent then
			velData[plr].bill:Destroy()
		end
		velData[plr] = nil
	end
end

local function startVelTracking(char, plr)
	stopVelTracking(plr)
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then
		hrp = char:WaitForChild("HumanoidRootPart", 3)
		if not hrp then return end
	end
	local bill = Instance.new("BillboardGui", char)
	bill.Size = UDim2.new(4, 0, 2, 0)
	bill.StudsOffset = Vector3.new(0, 4, 0)
	bill.AlwaysOnTop = true
	local lbl = Instance.new("TextLabel", bill)
	lbl.Size = UDim2.new(1, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.TextColor3 = Color3.new(1, 1, 1)
	lbl.TextStrokeTransparency = 0.3
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = 20
	lbl.RichText = true
	local trackedPlr = plr
	local trackedChar = char
	local trackedLbl = lbl
	local entry = {bill = bill, conn = nil, alerted = false}
	velData[plr] = entry
	entry.conn = Run.Heartbeat:Connect(function()
		if not velActive then return end
		if not trackedChar or not trackedChar.Parent then
			stopVelTracking(trackedPlr)
			return
		end
		local _, v = getVehicleSpeed(trackedChar)
		local vInt = math.floor(v)
		local currentLimit = velLimit
		local velText
		if currentLimit > 0 and vInt > currentLimit then
			velText = '<font color="rgb(255,255,255)">Vel: </font><font color="rgb(255,50,50)">' .. vInt .. ' (!)</font>'
		else
			velText = '<font color="rgb(255,255,255)">Vel: </font><font color="rgb(50,255,50)">' .. vInt .. '</font>'
		end
		if trackedLbl and trackedLbl.Parent then
			trackedLbl.Text = trackedPlr.Name .. "\n" .. velText
		end
		if currentLimit > 0 and vInt > currentLimit then
			if not entry.alerted then
				showSpeedAlert(trackedPlr.Name, vInt)
				entry.alerted = true
				task.delay(2, function() entry.alerted = false end)
			end
		end
	end)
end

local function activateVel()
	velActive = true
	velBtn.Text = "Desativar Velocidade"
	velBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character then startVelTracking(plr.Character, plr) end
		plr.CharacterAdded:Connect(function(char)
			task.wait(1)
			if velActive then startVelTracking(char, plr) end
		end)
	end
end

local function deactivateVel()
	velActive = false
	velBtn.Text = "Ativar Velocidade"
	velBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
	for plr in pairs(velData) do stopVelTracking(plr) end
end

velBtn.MouseButton1Click:Connect(function()
	if velActive then deactivateVel() else activateVel() end
end)

