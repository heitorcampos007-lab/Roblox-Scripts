--========================================================--
-- LOGICA PRINCIPAL DE VOLTAS
--========================================================--
local bestLap = {}
local wasInside = {}
local dataP = {}
local DELAY = 2
local record = math.huge

local function getPlayerTag(playerObject)
	local nameToUse = playerObject.DisplayName or playerObject.Name
	return string.upper(string.sub(nameToUse, 1, 3))
end

local function updateBoard()
	local arr = {}
	for _, plr in ipairs(Players:GetPlayers()) do
		local bestTime = bestLap[plr.Name]
		table.insert(arr, {n = plr, t = bestTime, sortTime = bestTime or math.huge})
	end
	table.sort(arr, function(a,b) return a.sortTime < b.sortTime end)
	record = arr[1] and arr[1].t or math.huge
	for i = 1,20 do
		if arr[i] then
			local pl = arr[i]
			rows[i].name.Text = getPlayerTag(pl.n)
			rows[i].soft.Text = "S"
			if pl.t then
				local diff = pl.t - record
				if math.abs(diff) < 0.001 then
					rows[i].time.Text = fmtDynamic(pl.t)
					rows[i].time.TextColor3 = Color3.fromRGB(128,0,128)
				else
					rows[i].time.Text = fmtDiff(diff)
					rows[i].time.TextColor3 = Color3.fromRGB(255,255,255)
				end
			else
				rows[i].time.Text = "NO TIME"
				rows[i].time.TextColor3 = Color3.fromRGB(255,255,255)
			end
		else
			rows[i].name.Text = ""
			rows[i].soft.Text = ""
			rows[i].time.Text = ""
		end
	end
end

Run.Heartbeat:Connect(function()
	for _, plr in ipairs(Players:GetPlayers()) do
		local char = plr.Character
		if not char then continue end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then continue end
		if not isInVehicle(plr) then
			wasInside[plr] = false
			continue
		end
		wasInside[plr] = wasInside[plr] or false
		dataP[plr] = dataP[plr] or {active=false, start=0, cool=false}
		local now = inside(root)
		local crossed = now and not wasInside[plr]
		wasInside[plr] = now
		local d = dataP[plr]
		if crossed then
			if d.cool then continue end
			if d.active then
				local lap = tick() - d.start
				if not bestLap[plr.Name] or lap < bestLap[plr.Name] then
					bestLap[plr.Name] = lap
					if lap < record then
						record = lap
						showFastLap(getPlayerTag(plr), lap)
					end
					updateBoard()
				end
				d.cool = true
				d.active = false
				task.delay(DELAY, function()
					d.cool = false
					d.active = true
					d.start = tick()
				end)
			else
				task.delay(DELAY, function()
					if not d.cool then
						d.active = true
						d.start = tick()
					end
				end)
			end
		end
	end
	updateBoard()
end)

Players.PlayerAdded:Connect(updateBoard)
Players.PlayerRemoving:Connect(updateBoard)

