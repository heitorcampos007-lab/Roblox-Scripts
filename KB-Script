--========================================================--
-- FUNÇÕES DE ANIMAÇÃO
--========================================================--
local TI_FAST   = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TI_SPRING = TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

local function setContentVisible(v)
	panelContent.Visible = v
end

-- Expanded → Minimized
local function toMinimized()
	if animating then return end
	animating = true
	setContentVisible(false)
	TweenService:Create(startPanel, TI_FAST, {
		Size = UDim2.new(0, PANEL_W, 0, MINI_H)
	}):Play()
	task.delay(0.25, function()
		panelState = "minimized"
		animating = false
	end)
end

-- Minimized → Expanded
local function toExpanded()
	if animating then return end
	animating = true
	startPanel.Visible = true
	TweenService:Create(startPanel, TI_SPRING, {
		Size = UDim2.new(0, PANEL_W, 0, PANEL_H)
	}):Play()
	task.delay(0.2, function()
		setContentVisible(true)
		panelState = "expanded"
		animating = false
	end)
end

-- Expanded/Minimized → Bubble
local function toBubble()
	if animating then return end
	animating = true
	-- Guarda posição atual para a bolinha aparecer no mesmo lugar
	local px = startPanel.Position.X.Offset
	local py = startPanel.Position.Y.Offset
	setContentVisible(false)
	-- Encolhe o painel até virar ponto
	TweenService:Create(startPanel, TI_FAST, {
		Size = UDim2.new(0, 0, 0, 0),
		BackgroundTransparency = 1
	}):Play()
	spStroke.Enabled = false
	task.delay(0.25, function()
		startPanel.Visible = false
		-- Mostra bolinha na posição do painel
		bubble.Position = UDim2.new(0, px, 0, py)
		bubble.Size = UDim2.new(0, 0, 0, 0)
		bubble.Visible = true
		TweenService:Create(bubble, TI_SPRING, {
			Size = UDim2.new(0, 44, 0, 44)
		}):Play()
		panelState = "bubble"
		animating = false
	end)
end

-- Bubble → Expanded
local function fromBubble()
	if animating then return end
	animating = true
	local px = bubble.Position.X.Offset
	local py = bubble.Position.Y.Offset
	-- Encolhe bolinha
	TweenService:Create(bubble, TI_FAST, {
		Size = UDim2.new(0, 0, 0, 0)
	}):Play()
	task.delay(0.2, function()
		bubble.Visible = false
		-- Mostra painel expandindo do mesmo ponto
		startPanel.Position = UDim2.new(0, px, 0, py)
		startPanel.Size = UDim2.new(0, 0, 0, 0)
		startPanel.BackgroundTransparency = 0
		startPanel.Visible = true
		spStroke.Enabled = true
		setContentVisible(false)
		TweenService:Create(startPanel, TI_SPRING, {
			Size = UDim2.new(0, PANEL_W, 0, PANEL_H)
		}):Play()
		task.delay(0.25, function()
			setContentVisible(true)
			panelState = "expanded"
			animating = false
		end)
	end)
end

